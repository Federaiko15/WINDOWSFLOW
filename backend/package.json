{
  "name": "windowsflow",
  "version": "1.0.0",
  "description": "App per la gestione di layout e temi in base all'hardware",
  "author": "Federico",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon --ignore profile-json.json src/app.js",
    "electron-dev": "electron .",
    "build": "electron-builder"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "socket.io": "^4.8.3",
    "usb": "^2.17.0"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^26.8.1",
    "nodemon": "^3.1.14"
  },
  "build": {
    "appId": "com.windowsflow.app",
    "productName": "WindowsFlow",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "src/**/*",
      "main.js",
      "public/**/*",
      "package.json",
      ".env"
    ],
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    }
  }
}
